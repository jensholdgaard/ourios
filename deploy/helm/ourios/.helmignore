# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Common VCS dirs
.git/
.gitignore
.bzr/
.bzrignore
.hg/
.hgignore
.svn/
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# Various IDEs
.project
.idea/
*.tmproj
.vscode/
# Chart docs — not shipped in the package. The README embeds the topology
# diagram via an absolute raw.githubusercontent.com URL (Artifact Hub does
# not resolve images from inside the chart artifact), so the PNG would be
# dead weight in the .tgz.
docs/*.py
docs/*.png
artifacthub-repo.yml
